<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="expo.modules.pausenative" >

    <uses-sdk android:minSdkVersion="24" />

    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application>
        <activity
            android:name="expo.modules.pausenative.BreatheActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTask"
            android:taskAffinity="expo.modules.pausenative.breathe"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <service
            android:name="expo.modules.pausenative.PauseAccessibilityService"
            android:exported="false"
            android:label="@string/pause_accessibility_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE" >
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/pause_accessibility_config" />
        </service>
        <service
            android:name="expo.modules.pausenative.PauseNotificationListener"
            android:exported="false"
            android:label="@string/pause_notif_label"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE" >
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>
    </application>

</manifest>